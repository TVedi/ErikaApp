# Supabase — replace with your project values
# Local Supabase CLI: run `supabase status` after `supabase start`

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never expose to client (coaching inquiry inserts from /apply)
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL for Origin checks on form submissions
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe Payment Link (public URL only — no secret keys, no webhooks)
# Baked at build time in Next.js — redeploy after changing on Vercel
NEXT_PUBLIC_STRIPE_STARTER_PAYMENT_LINK=

# Optional display label for Starter price (e.g. "$99/month")
NEXT_PUBLIC_STARTER_PRICE_LABEL=

# Cloudflare Turnstile (optional — form works without keys at launch)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
